// ============================================================
// 11_errors_test.scl —— 验证错误处理（跑这个脚本会出错，用于测试）
// 行号故意写在这里, 方便核对错误定位
// 第 8 行开始是测试用例
// ============================================================

// 错误 1: 读不存在的变量 (第 10 行)
// print undefined_var;

// 错误 2: 给不存在的变量赋值 (第 13 行)
// undefined_var = 42;

// 错误 3: 顶层 return (第 16 行)
// return 123;

// 错误 4: 函数参数数量不对 (第 19 行)
fn add2(x, y) { return x + y; }
print add2(1);    // 应报错: 需要 2 个参数, 得到 1
